# ---------------------------------------------------------------------------
# Template — copy to terraform.tfvars and fill values.
# terraform.tfvars is gitignored. NEVER commit values.
# ---------------------------------------------------------------------------

# Hetzner Cloud API token (Project → Security → API tokens, Read & Write).
hcloud_token = "REPLACE_ME"

# Operator SSH public key (OpenSSH single-line). Generate with:
#   ssh-keygen -t ed25519 -C "operator@laptop" -f ~/.ssh/mcp-approval2_ed25519
# then paste contents of ~/.ssh/mcp-approval2_ed25519.pub here.
operator_ssh_public_key = "ssh-ed25519 AAAAC3... operator@laptop"

# Cloudflare zone ID for ai-toolhub.org (32-char hex). Look up:
#   curl -s 'https://api.cloudflare.com/client/v4/zones?name=ai-toolhub.org' \
#     -H "Authorization: Bearer $CLOUDFLARE_API_TOKEN" | jq -r '.result[0].id'
cloudflare_zone_id = "REPLACE_ME_32_HEX"

# --- Optional overrides (defaults are fine for single-user) ---------------

# server_type           = "cx21"
# location              = "fsn1"
# allowed_ssh_ips       = ["198.51.100.42/32"]   # production: lock to your IP
# data_volume_size_gb   = 0                       # set e.g. 20 if you want pgdata on a sep. volume

# domain_mcp            = "mcp2.ai-toolhub.org"
# domain_knowledge      = "knowledge2.ai-toolhub.org"
# domain_app            = "app2.ai-toolhub.org"

# ---------------------------------------------------------------------------
# GitHub-Terraform (module: github-repo)
# ---------------------------------------------------------------------------
# The GitHub provider reads its credential from $GITHUB_TOKEN (classic PAT
# with `repo` + `workflow` scopes). NEVER put the token here — keep it in
# the shell env or a secrets manager. See runbook-github-terraform.md.
#
#   export GITHUB_TOKEN=ghp_xxxxx

cloudflare_api_token = "REPLACE_ME_CLOUDFLARE_API_TOKEN"

# R2 S3-compatible keys (Cloudflare → R2 → Manage API tokens).
r2_access_key_id     = "REPLACE_ME_R2_ACCESS_KEY_ID"
r2_secret_access_key = "REPLACE_ME_R2_SECRET_ACCESS_KEY"

# Separate SSH key for GH-Actions deploys (NOT the operator key).
# Generate locally with:
#   ssh-keygen -t ed25519 -f ~/.ssh/hetzner-deploy -N "" -C "gh-actions@mcp-approval2"
# Then paste the contents of ~/.ssh/hetzner-deploy below, AND put the matching
# .pub key into the VM's authorized_keys.
hetzner_deploy_ssh_private_key = <<-EOT
-----BEGIN OPENSSH PRIVATE KEY-----
REPLACE_ME
-----END OPENSSH PRIVATE KEY-----
EOT

# Internal service-token shared with the VM .env file.
# Generate: openssl rand -hex 32
mcp_approval_internal_token = "REPLACE_ME_HEX_64"

# Optional. Leave empty if you don't pull private images from ghcr.io.
# PAT scope: read:packages.
ghcr_token = ""
