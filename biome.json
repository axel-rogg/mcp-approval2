{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "include": [
      "apps/**/*.ts",
      "apps/**/*.tsx",
      "apps/**/*.js",
      "apps/**/*.mjs",
      "apps/**/*.json",
      "packages/**/*.ts",
      "packages/**/*.tsx",
      "packages/**/*.js",
      "packages/**/*.mjs",
      "packages/**/*.json",
      "*.ts",
      "*.mjs",
      "*.json"
    ],
    "ignore": [
      "**/node_modules",
      "**/dist",
      "**/build",
      "**/.next",
      "**/.turbo",
      "**/coverage",
      "**/.nyc_output",
      "**/migrations/meta",
      "**/drizzle/meta",
      "package-lock.json",
      "tsconfig.tsbuildinfo"
    ]
  },
  "organizeImports": {
    "enabled": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100,
    "formatWithErrors": false
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "always",
      "bracketSpacing": true
    }
  },
  "json": {
    "formatter": {
      "indentWidth": 2,
      "lineWidth": 100,
      "trailingCommas": "none"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "error",
        "noConsoleLog": "warn",
        "noEmptyBlockStatements": "warn"
      },
      "style": {
        "useImportType": "error",
        "useExportType": "error",
        "noDefaultExport": "error",
        "useNodejsImportProtocol": "error",
        "useConst": "error",
        "useTemplate": "warn"
      },
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "warn",
        "useExhaustiveDependencies": "warn"
      },
      "performance": {
        "noBarrelFile": "error",
        "noReExportAll": "error"
      },
      "complexity": {
        "noUselessTypeConstraint": "error",
        "noStaticOnlyClass": "warn"
      },
      "nursery": {
        "useSortedClasses": "off"
      }
    }
  },
  "overrides": [
    {
      "include": [
        "apps/web/**/app/**/page.tsx",
        "apps/web/**/app/**/layout.tsx",
        "apps/web/**/app/**/route.ts",
        "apps/web/**/app/**/error.tsx",
        "apps/web/**/app/**/loading.tsx",
        "apps/web/**/app/**/not-found.tsx",
        "apps/web/**/next.config.*",
        "apps/web/**/middleware.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    },
    {
      "include": ["**/index.ts", "**/index.tsx"],
      "linter": {
        "rules": {
          "performance": {
            "noBarrelFile": "off",
            "noReExportAll": "off"
          }
        }
      }
    },
    {
      "include": [
        "**/*.config.ts",
        "**/*.config.mts",
        "**/*.config.mjs",
        "**/vitest.workspace.ts",
        "**/drizzle.config.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    },
    {
      "include": [
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.spec.ts",
        "**/*.spec.tsx",
        "**/test/**/*.ts",
        "**/tests/**/*.ts"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off",
            "noConsoleLog": "off"
          }
        }
      }
    }
  ]
}
