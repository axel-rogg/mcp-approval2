# mcp-approval2 — local development env-vars
#
# Quickstart:
#   cp .env.example .env
#   bash scripts/dev.sh
#
# All values below are DEV-DEFAULTS, safe to commit as examples but
# UNSAFE for production. Anything labeled CHANGE-IN-PROD must be rotated
# before deploy. See docs/setup/local-dev.md for context.

# ─────────────────────────────────────────────────────────────────────
# Database (Postgres 16 + pgvector, see docker-compose.yml)
# ─────────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mcp_approval2
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=mcp_approval2
# Set to 'true' to log all SQL via drizzle (verbose; off by default).
DATABASE_LOG=false

# ─────────────────────────────────────────────────────────────────────
# OpenBao (Vault-fork, MPL-2.0; KEK-provider per PLAN §5)
# ─────────────────────────────────────────────────────────────────────
# In dev-mode the root token is whatever VAULT_TOKEN is set to.
# In prod you'd use AppRole-auth with rotated secret_id.
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=root-dev-token-CHANGE-IN-PROD
# Path under which the transit-engine is mounted (default 'transit').
VAULT_TRANSIT_PATH=transit

# ─────────────────────────────────────────────────────────────────────
# Object Storage (S3-compatible — MinIO locally, R2/GCS in prod)
# ─────────────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=mcp-approval2
S3_REGION=eu-central-1
# Force path-style addressing for MinIO. R2/GCS may need 'auto'.
S3_FORCE_PATH_STYLE=true

# ─────────────────────────────────────────────────────────────────────
# Google OAuth (login front-door — PLAN §3.2)
# ─────────────────────────────────────────────────────────────────────
# Get these from https://console.cloud.google.com/apis/credentials
# Redirect-URI to register: http://localhost:8787/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────
# Google Vertex AI (embeddings + chat — PLAN §8)
# ─────────────────────────────────────────────────────────────────────
VERTEX_AI_PROJECT_ID=
VERTEX_AI_REGION=europe-west4
# Path to a service-account JSON key file (mounted into the container in prod).
# Leave blank in dev if you don't intend to call Vertex AI locally.
GOOGLE_APPLICATION_CREDENTIALS=
# Models (overridable for experiments).
VERTEX_EMBEDDING_MODEL=text-embedding-005
VERTEX_CHAT_MODEL=gemini-2.5-flash

# ─────────────────────────────────────────────────────────────────────
# Session / JWT keys
# ─────────────────────────────────────────────────────────────────────
# SESSION_SIGNING_KEY: HMAC-SHA256 secret for session-JWTs (PLAN §3.5).
#   Generate with: openssl rand -base64 64
# JWT_RS256_PRIVATE_KEY_PEM / JWT_RS256_PUBLIC_KEY_PEM: RSA-2048 keypair for
#   service-JWTs signed by mcp-approval2 → mcp-knowledge2 (PLAN §2.1, ADR-0001).
#   PEM format (PKCS#8 private, SPKI public). Generate with:
#     openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out priv.pem
#     openssl rsa -in priv.pem -pubout -out pub.pem
#   Then put each PEM (newlines OK; or escape with \n) into the env-vars below.
#   JWT_KID identifies the key in the JWKS document — bump on rotation.
# JWT_PRIVATE_KEY: legacy alias for JWT_RS256_PRIVATE_KEY_PEM (still honored
#   if the new var is unset; drop after cutover).
SESSION_SIGNING_KEY=
JWT_RS256_PRIVATE_KEY_PEM=
JWT_RS256_PUBLIC_KEY_PEM=
JWT_KID=key-dev-1
JWT_PRIVATE_KEY=

# ─────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────
PORT=8787
BASE_URL=http://localhost:8787
# WebAuthn-Relying-Party config (PLAN §3.4)
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=mcp-approval2
# Comma-separated list of origins the server will accept for WebAuthn.
WEBAUTHN_ORIGINS=http://localhost:8787

# ─────────────────────────────────────────────────────────────────────
# Master-Encryption-Key (LocalKekProvider — DEV ONLY)
# ─────────────────────────────────────────────────────────────────────
# Used by the dev-fallback KekProvider when VAULT_ADDR is unreachable.
# In prod this MUST be unset; OpenBao is the only KEK-source.
# Generate with: openssl rand -base64 32
MASTER_KEY_BASE64=

# ─────────────────────────────────────────────────────────────────────
# mcp-knowledge2 (paralleler Storage-Service — PLAN §7, AS-3 §1.7)
# ─────────────────────────────────────────────────────────────────────
# URL of the mcp-knowledge2 service. Leave blank during early phase-0;
# the server will skip storage-calls if unset.
#
# AS-3-NAMING: kanonischer Name ist MCP_KNOWLEDGE_URL. Der alte Name
# KNOWLEDGE_URL wird weiter unterstuetzt (Backwards-Compat), bevorzugt
# wird MCP_KNOWLEDGE_URL wenn beide gesetzt sind.
KNOWLEDGE_URL=
MCP_KNOWLEDGE_URL=

# Shared SERVICE_TOKEN fuer S2S-Calls approval2 → KC2 (AS-3).
# approval2 sendet diesen als `Authorization: Bearer <token>` PLUS einen
# kurzlebigen OBO-JWT als `X-On-Behalf-Of: <jwt>`. KC2 verifiziert beides.
# Generate: openssl rand -base64 48. Min 32 chars. Rotate alle 30d mit
# 7d-Overlap (siehe Big-Bang §2.4).
MCP_KNOWLEDGE_SERVICE_TOKEN=

# AS-3: `iss`-Claim der OBO-JWTs die approval2 an KC2 sendet.
# KC2 verifiziert via JWKS-Lookup auf <SELF_OAUTH_ISSUER>/.well-known/jwks.json.
# Fallback wenn leer: BASE_URL/ORIGIN.
SELF_OAUTH_ISSUER=

# JWKS-Endpoint mcp-knowledge2 fetches from us to verify our service-JWTs.
JWKS_PATH=/.well-known/jwks.json

# AS-3: optional zusaetzliche akzeptierte Google-Audiences fuer inbound
# `verifyIdToken`-Calls (CSV). Default: nur eigene GOOGLE_OAUTH_CLIENT_ID.
GOOGLE_ALLOWED_AUDIENCES=

# Pre-shared internal service-token. mcp-knowledge2 (and other first-party
# services) include this as `Authorization: Bearer …` or `X-Service-Token: …`
# when calling /internal/v1/* (e.g. /internal/v1/dek/resolve).
# Generate with: openssl rand -base64 48
# MUST be at least 32 chars. Rotate by setting both old + new in mcp-knowledge2
# during the cutover, then drop the old value here.
MCP_APPROVAL_INTERNAL_TOKEN=

# ─────────────────────────────────────────────────────────────────────
# Logging / Diagnostics
# ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
