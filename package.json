{
  "name": "mcp-approval2",
  "version": "0.0.1",
  "private": true,
  "description": "Greenfield Multi-User MCP-Approval-Server with portable Adapter-Layer (Postgres + CF Workers). See docs/plans/active/PLAN-architecture-v1.md.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev": "npm run dev --workspace=apps/server",
    "db:migrate": "npm run db:migrate --workspace=apps/server",
    "db:reset": "bash scripts/db-reset.sh",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "vitest": "^4.1.6",
    "@biomejs/biome": "^1.9.0"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.0"
    }
  }
}
