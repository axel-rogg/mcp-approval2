{
  "name": "@mcp-approval2/core",
  "version": "0.0.1",
  "private": true,
  "description": "Core crypto + shared primitives for mcp-approval2 (AES-GCM, HKDF, AAD-Builder, JWT, PRF-XOR). Web-Crypto-API based, runs on Node 20+ and CF Workers.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./crypto": {
      "source": "./src/crypto/index.ts",
      "types": "./dist/crypto/index.d.ts",
      "default": "./dist/crypto/index.js"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@noble/hashes": "^1.5.0",
    "jose": "^5.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.6"
  }
}
