{
  "name": "@mcp-approval2/adapters",
  "version": "0.0.1",
  "private": true,
  "description": "Portable runtime adapters (Db / Blob / Kek / Ai) for mcp-approval2.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./db": "./src/db/interface.ts",
    "./db/postgres": "./src/db/postgres.ts",
    "./db/sqlite": "./src/db/sqlite.ts",
    "./blob": "./src/blob/interface.ts",
    "./blob/s3": "./src/blob/s3.ts",
    "./blob/local-fs": "./src/blob/local-fs.ts",
    "./kek": "./src/kek/interface.ts",
    "./kek/local": "./src/kek/local.ts",
    "./kek/openbao": "./src/kek/openbao.ts",
    "./ai": "./src/ai/interface.ts",
    "./ai/vertex": "./src/ai/vertex.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@noble/hashes": "^1.6.0",
    "better-sqlite3": "^11.5.0",
    "drizzle-orm": "^0.36.0",
    "google-auth-library": "^9.15.0",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
