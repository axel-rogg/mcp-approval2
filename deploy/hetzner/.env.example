# .env.example — copy to .env and fill in real values.
#
# Generate machine secrets with:  bash generate-secrets.sh > .env
# Then edit DOMAIN_*, GOOGLE_OAUTH_*, VERTEX_AI_* manually.
#
# NEVER commit .env. It is gitignored.

# ============================================================================
# Database
# ============================================================================
# Postgres user is hardcoded to "app" in docker-compose.yml. The init script
# also creates the "knowledge2" database with the same owner.
POSTGRES_PASSWORD=replace-me-with-openssl-rand-hex-24

# ============================================================================
# Vault / OpenBao
# ============================================================================
# Set to the root token printed by `bash vault-init.sh`. For production,
# rotate to an AppRole-issued token (see vault-init.sh output).
VAULT_TOKEN=set-after-bao-operator-init

# Optional: AppRole credentials (preferred over root token for runtime use).
# Uncomment + set after vault-init.sh prints them.
# VAULT_APPROLE_ROLE_ID=
# VAULT_APPROLE_SECRET_ID=

# ============================================================================
# Internal Service Token (Sub-MCP gateways ⇄ approval2)
# ============================================================================
# Used by Sub-MCPs (cf/github/gws/utils/gcloud) to call mcp-approval2's
# internal endpoints. Separate from the approval2 → knowledge2 token below.
MCP_APPROVAL_INTERNAL_TOKEN=replace-me-with-openssl-rand-hex-32

# ============================================================================
# AS-3 — mcp-approval2 → mcp-knowledge2 Two-Factor Bearer
# ============================================================================
# Shared SERVICE_TOKEN that approval2 sends in `Authorization: Bearer` on
# every S2S call to KC2 (paired with `X-On-Behalf-Of: <OBO-JWT>`). KC2 reads
# it from its own SERVICE_TOKEN env. ROTATE TOGETHER (PLAN-as3-autonomous.md
# A-D3 — 30d cadence, 7d overlap window).
# Generate: openssl rand -hex 32  (must be ≥32 chars / 32 bytes)
MCP_KNOWLEDGE_SERVICE_TOKEN=replace-me-with-openssl-rand-hex-32

# ============================================================================
# AS-3 — KC2 OAuth-Facade (Claude.ai direct path)
# ============================================================================
# Separate Google OAuth Client-ID for KC2's own DCR-OAuth-2.1-facade (it
# proxies users through to Google for the Claude.ai-direct flow). Different
# from GOOGLE_OAUTH_CLIENT_ID above — approval2 has its own.
KC_GOOGLE_OAUTH_CLIENT_ID=
KC_GOOGLE_OAUTH_CLIENT_SECRET=

# Optional Workspace `hd` allowlist (CSV). Empty = allow any domain.
GOOGLE_HD_ALLOWLIST=

# KC2 KMS provider:
#   - 'openbao'    — pilot/prod default. Shares the openbao container with
#                     approval2; transit-mount must be the same as
#                     KC_OPENBAO_TRANSIT_PATH (default 'transit').
#   - 'hkdf_local' — dev/solo fallback. Requires KC_KMS_MASTER_KEY_B64.
KC_KMS_PROVIDER=openbao
KC_OPENBAO_TRANSIT_PATH=transit
# Only required when KC_KMS_PROVIDER=hkdf_local. 32-byte base64.
KC_KMS_MASTER_KEY_B64=

# Blob (S3-compatible). For pilot you can point at the same MinIO/HetznerObjectStorage
# bucket as approval2, just use a DIFFERENT BUCKET name to keep namespaces clean.
KC_BLOB_ENDPOINT=https://eu-central-1.linodeobjects.com
KC_BLOB_REGION=eu-central
KC_BLOB_ACCESS_KEY=
KC_BLOB_SECRET_KEY=
KC_BLOB_BUCKET=knowledge2
KC_BACKUP_BUCKET=knowledge2-backup

# Embedding-Model (default text-multilingual-embedding-002 — see CLAUDE.md
# user-memory: multilingual default).
VERTEX_MODEL=text-multilingual-embedding-002

# ============================================================================
# mcp-knowledge2 backup master key (base64, 32 bytes)
# ============================================================================
# Used by mcp-knowledge2 to encrypt nightly backups before uploading to
# Storage Box. Lose this key → cannot decrypt backups. BACKUP OFFLINE.
KNOWLEDGE_BACKUP_MASTER_KEY_BASE64=replace-me-with-openssl-rand-32-base64

# ============================================================================
# JWT RS256 signing keys
# ============================================================================
# Newlines must be encoded as literal "\n" inside the .env value. The shell
# unescapes them when Docker reads the variable (Compose 1.27+ does this).
# Use `bash generate-secrets.sh` to produce these in the correct format.
JWT_RS256_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
JWT_RS256_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"
JWT_KID=key-2026-05-13

# ============================================================================
# Domains (Phase A: ai-toolhub.org subdomains)
# ============================================================================
# These MUST have A/AAAA records pointing to this VM before `setup.sh` runs.
# Caddy uses them for Let's Encrypt challenges.
DOMAIN_MCP=mcp2.ai-toolhub.org
DOMAIN_KNOWLEDGE=knowledge2.ai-toolhub.org
DOMAIN_APP=app2.ai-toolhub.org

# Email for Let's Encrypt expiry notifications.
ACME_EMAIL=admin@ai-toolhub.org

# ============================================================================
# Coop-Bypass FQDN (Hetzner-default Reverse-DNS)
# ============================================================================
# Hetzner gibt jeder VM unter `*.your-server.de` automatisch eine FQDN.
# Diese wird vom Coop-Zscaler-Proxy durchgelassen, waehrend *.ai-toolhub.org
# als "newly registered" geblockt wird. Let's Encrypt funktioniert fuer
# diese FQDN — Caddy holt das Cert automatisch.
#
# Wert kommt aus terraform output:
#   cd terraform/environments/privat && terraform output default_hetzner_fqdn_v4
#
# Format: static.<reversed-IP-octets>.clients.your-server.de
# Beispiel: static.45.123.75.5.clients.your-server.de  fuer VM-IP 5.75.123.45
#
# Optional — wenn leer/unset, omitted render-config.sh den Coop-Bypass-vhost.
# Siehe docs/runbooks/runbook-coop-bypass.md.
HETZNER_FQDN_V4=

# ============================================================================
# Multi-Origin (CSV) — Pflicht-Liste fuer WebAuthn-Origin-Check + CORS
# ============================================================================
# Alle 3 FQDNs muessen drin sein, sonst schlaegt der Origin-Check der
# Approval-PWA / WebAuthn-Registration fehl, sobald jemand von einer der
# Origins kommt. Verwertet vom Server-Code (apps/server/src/lib/config.ts)
# als CSV-geparste Allowlist.
#
# Wert kommt aus terraform output:
#   cd terraform/environments/privat && terraform output allowed_origins_csv
ALLOWED_ORIGINS=https://mcp2.ai-toolhub.org,https://app2.ai-toolhub.org,https://static.X.X.X.X.clients.your-server.de

# ============================================================================
# Google OAuth (Front-Door Login)
# ============================================================================
# Create at https://console.cloud.google.com/apis/credentials
# OAuth-Consent-Screen: External, scopes "openid email"
# Authorized redirect URIs: https://${DOMAIN_MCP}/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ============================================================================
# Vertex AI (optional — only required if AI features are enabled)
# ============================================================================
# Service-Account JSON must be placed at deploy/hetzner/secrets/vertex-sa.json
# (mounted read-only into the mcp-approval2 container at /secrets/vertex-sa.json).
VERTEX_AI_PROJECT_ID=
VERTEX_AI_REGION=europe-west4

# ============================================================================
# Sub-MCPs on Cloudflare (cross-cloud HTTPS)
# ============================================================================
# Most Sub-MCPs have stable URLs and are hardcoded in docker-compose.yml.
# Only set this if you use a custom GitHub-MCP endpoint.
GATEWAY_GITHUB_URL=

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=info

# ============================================================================
# Container image tags (override for canary / rollback)
# ============================================================================
TAG=latest
KNOWLEDGE_TAG=latest

# ============================================================================
# Watchtower Auto-Updates
# ============================================================================
# Watchtower polled ghcr.io und pulled neue Image-Tags automatisch.
# Überwacht NUR Container mit Label `com.centurylinklabs.watchtower.enable=true`
# → aktuell mcp-approval2 + mcp-knowledge2. Postgres/OpenBao/Caddy bleiben
# manuell (siehe README "Auto-Updates via Watchtower").

# Polling-Intervall (Sekunden, default 300 = 5 min)
WATCHTOWER_POLL_INTERVAL=300

# Log-Level (debug | info | warn | error)
WATCHTOWER_LOG_LEVEL=info

# GHCR-Auth (für private Images — bei public Images optional, leer lassen).
# Token erzeugen: https://github.com/settings/tokens → scope `read:packages`
GHCR_USER=axel-rogg
GHCR_TOKEN=

# Optional: Notifications (Slack, Discord, Email, generic webhook).
# Details + Beispiele: deploy/hetzner/watchtower-notifications.md
# Format: shoutrrr-URL (https://github.com/containrrr/shoutrrr#supported-services)
# Beispiel Slack: slack://<bot_token>@<channel_id>
WATCHTOWER_NOTIFICATIONS=
WATCHTOWER_NOTIFICATION_URL=
WATCHTOWER_NOTIFICATIONS_LEVEL=info
